# ── Core ──────────────────────────────────────────────────────────────────────
ENV=dev
SECRET_KEY=change-this-to-a-random-32-char-string

# ── Database ───────────────────────────────────────────────────────────────────
# Managed by Docker Compose — override only when connecting to an external DB.
# DATABASE_URL=postgresql+psycopg://notes:notes@db:5432/notes
POSTGRES_DB=notes
POSTGRES_USER=notes
POSTGRES_PASSWORD=changeme

# ── RabbitMQ ───────────────────────────────────────────────────────────────────
# Required in production. Leave empty in dev to use asyncio fallback.
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ── pgAdmin ────────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=changeme

# ── App URL (used for email links & OAuth redirects) ───────────────────────────
APP_BASE_URL=http://localhost:8000

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
# Leave empty in dev — links are printed to console instead
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@yourdomain.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# ── Google OAuth ───────────────────────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Microsoft OAuth ────────────────────────────────────────────────────────────
# https://portal.azure.com → App registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# ── Search & AI ────────────────────────────────────────────────────────────────
MEILI_MASTER_KEY=
MEILI_URL=http://localhost:7700
MEILI_KEY=

# Embedding model for semantic search (PostgreSQL only).
# Leave empty to use keyword search only.
# Examples:
#   text-embedding-3-small  (OpenAI, 1536 dims)
#   ollama/nomic-embed-text (local Ollama, 768 dims)
#   ollama/all-minilm       (local Ollama, 384 dims)
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=1536
