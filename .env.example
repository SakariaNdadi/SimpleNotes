# ── Core ──────────────────────────────────────────────────────────────────────
ENV=dev
SECRET_KEY=change-this-to-a-random-32-char-string

# ── Database ───────────────────────────────────────────────────────────────────
# Dev (SQLite)
DATABASE_URL=sqlite:///./notes.db
# Prod (PostgreSQL + pgvector)
# DATABASE_URL=postgresql://notes:password@db:5432/notes
# POSTGRES_PASSWORD=changeme

# ── App URL (used for email links & OAuth redirects) ───────────────────────────
APP_BASE_URL=http://localhost:8000

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
# Leave empty in dev — links are printed to console instead
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@yourdomain.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# ── Google OAuth ───────────────────────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Microsoft OAuth ────────────────────────────────────────────────────────────
# https://portal.azure.com → App registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

MEILI_MASTER_KEY=